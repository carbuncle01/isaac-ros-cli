# 9. FoundationStereo Models Download (x86_64 only)
# 16GB未満のGPUメモリを想定し、デフォルトをlow_resに設定
ENV FOUNDATIONSTEREO_MODEL_RES=low_res

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    if [ "$(uname -m)" = "x86_64" ]; then \
        echo "Architecture is x86_64. Installing FoundationStereo models..." && \
        apt-get update && apt-get install -y \
            ros-jazzy-isaac-ros-foundationstereo-models-install \
        && rm -rf /var/lib/apt/lists/* && \
        # ROS 2環境を読み込み、モデルダウンロードスクリプトを実行
        . /opt/ros/jazzy/setup.sh && \
        ros2 run isaac_ros_foundationstereo_models_install install_foundationstereo_models.sh --eula --model_res ${FOUNDATIONSTEREO_MODEL_RES}; \
    else \
        echo "Skipping FoundationStereo model download. (Architecture is $(uname -m), not x86_64)"; \
    fi