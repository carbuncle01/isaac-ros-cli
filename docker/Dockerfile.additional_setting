# Additional Isaac ROS development settings.
ARG BASE_IMAGE=ubuntu:24.04
FROM ${BASE_IMAGE}

USER root
SHELL ["/bin/bash", "-c"]
ENV DEBIAN_FRONTEND=noninteractive

# 1. CycloneDDS settings.
COPY middleware_profiles/cyclonedds.xml /etc/cyclonedds.xml
ENV RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
ENV CYCLONEDDS_URI=file:///etc/cyclonedds.xml
ENV ROS_DOMAIN_ID=50

# 2. Admin user settings.
# The current Isaac ROS entrypoint creates/updates this user at container start
# so it can match the host UID/GID. Avoid creating it at build time.
ARG USERNAME=admin
ENV USERNAME=${USERNAME}

# 3. Workspace.
WORKDIR /workspaces

# 4. JetRacer support.
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    apt-get update && apt-get install -y \
        ca-certificates \
        curl \
        git \
        gnupg \
        lsb-release \
        python3-pip \
        python3-setuptools \
        sudo \
        gosu \
        udev \
    && rm -rf /var/lib/apt/lists/*

# Ensure the Isaac ROS 4.4 Jazzy apt repository is available for the package listing below.
ARG ISAAC_DEBIAN_COMPONENTS="main external-main"
ARG ISAAC_DEBIAN_DISTRO_SUFFIX=""
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    k="/usr/share/keyrings/nvidia-isaac-ros.gpg" \
    && curl -fsSL https://isaac.download.nvidia.com/isaac-ros/repos.key | gpg --dearmor | tee "$k" > /dev/null \
    && f="/etc/apt/sources.list.d/nvidia-isaac-ros.list" \
    && s="deb [signed-by=$k] https://isaac.download.nvidia.com/isaac-ros/release-4.4 $(lsb_release -cs)${ISAAC_DEBIAN_DISTRO_SUFFIX} ${ISAAC_DEBIAN_COMPONENTS}" \
    && echo "$s" | tee "$f" > /dev/null \
    && apt-get update \
    && rm -rf /var/lib/apt/lists/*

RUN set -eux; \
    cd /tmp; \
    git clone --depth 1 https://github.com/NVIDIA-AI-IOT/jetracer.git; \
    cd jetracer; \
    python3 setup.py install; \
    python3 -m pip install --break-system-packages \
        traitlets \
        questionary \
        jetson-gpio; \
    cd /; \
    rm -rf /tmp/jetracer

# 5. Extra Python packages are intentionally left for a future layer.
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    apt-get update && apt-get install -y \
        python3-pip \
    && rm -rf /var/lib/apt/lists/*

# jetsonの場合、torchとtorchvisionをインストール

RUN set -eux; \
    # Install appropriate torch package depending on architecture (Jetson vs x86)
    if [ "$(uname -m)" = "aarch64" ]; then \
        python3 -m pip install --break-system-packages \
            torch==2.11.0 \
            torchvision==0.25.0 \
            --index-url https://pypi.jetson-ai-lab.io/sbsa/cu130; \
    else \
        python3 -m pip install --ignore-installed --break-system-packages \
            torch==2.11.0 \
            torchvision \
            opencv-python \
            tqdm \
            rosbags \
            omegaconf \
            hydra-core \
            tensorboard \
            onnx \
            onnxruntime; \
    fi

RUN set -x && \
    if [ "$(uname -m)" = "x86_64" ]; then \
        pip install --break-system-packages --ignore-installed --no-cache-dir "matplotlib>=3.5,<4" "scipy>=1.8,<2" && \
        pip install --break-system-packages --ignore-installed --no-cache-dir "quadprog>=0.1.11" && \
        pip install --break-system-packages --ignore-installed --no-cache-dir "git+https://github.com/TUMFTM/trajectory_planning_helpers.git@master" --no-deps; \
    fi

# 6. Entrypoint additions.
RUN mkdir -p /usr/local/bin/scripts/entrypoint_additions
COPY scripts/entrypoint_additions/*.sh /usr/local/bin/scripts/entrypoint_additions/
RUN chmod +x /usr/local/bin/scripts/entrypoint_additions/*.sh || true
