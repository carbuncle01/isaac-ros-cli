# Additional Isaac ROS development settings.
ARG BASE_IMAGE=ubuntu:24.04
FROM ${BASE_IMAGE}

USER root
SHELL ["/bin/bash", "-c"]
ENV DEBIAN_FRONTEND=noninteractive

# CycloneDDS runtime defaults. The profile is copied near the end so edits to
# the XML do not invalidate the heavy apt and pip layers above it.
ENV RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
ENV CYCLONEDDS_URI=file:///etc/cyclonedds.xml
ENV ROS_DOMAIN_ID=50

# The current Isaac ROS entrypoint creates/updates this user at container start
# so it can match the host UID/GID. Avoid creating it at build time.
ARG USERNAME=admin
ENV USERNAME=${USERNAME}

WORKDIR /workspaces

# Base utilities needed by this layer.
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    apt-get update && apt-get install -y \
        ca-certificates \
        curl \
        git \
        gnupg \
        gosu \
        lsb-release \
        python3-pip \
        python3-setuptools \
        python3-venv \
        sudo \
        udev \
    && rm -rf /var/lib/apt/lists/*

# Ensure the Isaac ROS 4.5 Jazzy apt repository is available for the package listing below.
ARG ISAAC_DEBIAN_COMPONENTS="main external-main"
ARG ISAAC_DEBIAN_DISTRO_SUFFIX=""
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    k="/usr/share/keyrings/nvidia-isaac-ros.gpg" \
    && curl -fsSL https://isaac.download.nvidia.com/isaac-ros/repos.key | gpg --dearmor | tee "$k" > /dev/null \
    && f="/etc/apt/sources.list.d/nvidia-isaac-ros.list" \
    && s="deb [signed-by=$k] https://isaac.download.nvidia.com/isaac-ros/release-4.5 $(lsb_release -cs)${ISAAC_DEBIAN_DISTRO_SUFFIX} ${ISAAC_DEBIAN_COMPONENTS}" \
    && echo "$s" | tee "$f" > /dev/null \
    && apt-get update \
    && rm -rf /var/lib/apt/lists/*

# JetRacer support.
RUN set -eux; \
    cd /tmp; \
    git clone --depth 1 https://github.com/NVIDIA-AI-IOT/jetracer.git; \
    cd jetracer; \
    python3 setup.py install; \
    python3 -m pip install --break-system-packages \
        traitlets \
        questionary \
        jetson-gpio; \
    cd /; \
    rm -rf /tmp/jetracer

# Python environment for x86_64 training and trajectory planning.
# Activate explicitly with: source /opt/env/bin/activate
RUN set -eux; \
    if [ "$(uname -m)" = "x86_64" ]; then \
        python3 -m venv /opt/env; \
        /opt/env/bin/python -m pip install --upgrade \
            pip==26.1.2 \
            setuptools==81.0.0; \
        /opt/env/bin/python -m pip install \
            torch==2.11.0 \
            torchvision==0.26.0 \
            numpy==2.4.6 \
            opencv-python==4.13.0.92 \
            tqdm==4.68.2 \
            rosbags==0.11.3 \
            omegaconf==2.3.1 \
            hydra-core==1.3.3 \
            PyYAML==6.0.2 \
            tensorboard==2.20.0 \
            onnx==1.21.0 \
            onnxruntime==1.26.0 \
            matplotlib==3.11.0 \
            scipy==1.17.1 \
            quadprog==0.1.13 \
            "ultralytics>=8.3,<9"; \
        /opt/env/bin/python -m pip install \
            "git+https://github.com/carbuncle01/trajectory_planning_helpers.git@master" \
            --no-deps; \
    fi

